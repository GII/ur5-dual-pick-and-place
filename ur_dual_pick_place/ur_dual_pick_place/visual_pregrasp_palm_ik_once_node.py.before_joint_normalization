#!/usr/bin/env python3
# -----------------------------------------------------------------------------
# TFG Daniel Rodríguez Rivas
#
# visual_pregrasp_palm_ik_once:
#   Hace que el objetivo de agarre sea la palma de la SoftHand, no tool0.
#
# Flujo:
#   1. Lee /object_tracker/detections_base.
#   2. Selecciona un objeto.
#   3. Define palm_target = objeto + offset_z.
#   4. Lee T_base_palm_actual y T_tool_palm.
#   5. Calcula T_base_tool_target = T_base_palm_target * inv(T_tool_palm).
#   6. Llama /compute_ik para ur_dual_I_tool0.
#   7. Compara joints actuales vs IK.
#   8. Si ik_only=True, no planifica ni mueve.
# -----------------------------------------------------------------------------

import math
from copy import deepcopy

import numpy as np
import rclpy
from rclpy.node import Node
from rclpy.action import ActionClient
from rclpy.duration import Duration
from rclpy.time import Time

from sensor_msgs.msg import JointState
from geometry_msgs.msg import PoseStamped
from tf2_ros import Buffer, TransformListener, TransformException

from tf_transformations import (
    quaternion_matrix,
    quaternion_from_matrix,
    inverse_matrix,
)

from moveit_msgs.srv import GetPositionIK
from moveit_msgs.action import MoveGroup
from moveit_msgs.msg import (
    MotionPlanRequest,
    Constraints,
    JointConstraint,
    RobotState,
    DisplayTrajectory,
)

from stereo_location_interfaces.msg import ObjDetArray


RIGHT_ARM_JOINTS = [
    "ur_dual_I_elbow_joint",
    "ur_dual_I_shoulder_lift_joint",
    "ur_dual_I_shoulder_pan_joint",
    "ur_dual_I_wrist_1_joint",
    "ur_dual_I_wrist_2_joint",
    "ur_dual_I_wrist_3_joint",
]


class VisualPregraspPalmIKOnce(Node):
    def __init__(self):
        super().__init__("visual_pregrasp_palm_ik_once")

        self.declare_parameter("detections_topic", "/object_tracker/detections_base")
        self.declare_parameter("joint_states_topic", "/joint_states")

        self.declare_parameter("target_frame", "ur_dual_I_base_link")
        self.declare_parameter("planning_group", "Right_arm")
        self.declare_parameter("ik_link", "ur_dual_I_tool0")
        self.declare_parameter("palm_link", "qbhand2m1_palm_link")

        self.declare_parameter("target_class", "")
        self.declare_parameter("min_confidence", 0.6)

        # Pre-grasp: la palma queda sobre el objeto a esta altura.
        self.declare_parameter("pregrasp_offset_z", 0.35)

        # Modos seguros.
        self.declare_parameter("ik_only", True)
        self.declare_parameter("plan_only", True)

        # Filtro de seguridad.
        self.declare_parameter("max_joint_delta_rad", 1.2)

        self.declare_parameter("velocity_scaling", 0.03)
        self.declare_parameter("acceleration_scaling", 0.03)

        self.declare_parameter("wait_detection_timeout_s", 5.0)
        self.declare_parameter("wait_joint_state_timeout_s", 5.0)
        self.declare_parameter("ik_timeout_s", 2.0)

        self.detections_topic = self.get_parameter("detections_topic").value
        self.joint_states_topic = self.get_parameter("joint_states_topic").value
        self.target_frame = self.get_parameter("target_frame").value
        self.planning_group = self.get_parameter("planning_group").value
        self.ik_link = self.get_parameter("ik_link").value
        self.palm_link = self.get_parameter("palm_link").value
        self.target_class = self.get_parameter("target_class").value.strip()
        self.min_confidence = float(self.get_parameter("min_confidence").value)
        self.pregrasp_offset_z = float(self.get_parameter("pregrasp_offset_z").value)
        self.ik_only = bool(self.get_parameter("ik_only").value)
        self.plan_only = bool(self.get_parameter("plan_only").value)
        self.max_joint_delta_rad = float(self.get_parameter("max_joint_delta_rad").value)
        self.velocity_scaling = float(self.get_parameter("velocity_scaling").value)
        self.acceleration_scaling = float(self.get_parameter("acceleration_scaling").value)
        self.wait_detection_timeout_s = float(self.get_parameter("wait_detection_timeout_s").value)
        self.wait_joint_state_timeout_s = float(self.get_parameter("wait_joint_state_timeout_s").value)
        self.ik_timeout_s = float(self.get_parameter("ik_timeout_s").value)

        self.latest_detections = None
        self.latest_joint_state = None

        self.create_subscription(
            ObjDetArray,
            self.detections_topic,
            self.on_detections,
            10,
        )

        self.create_subscription(
            JointState,
            self.joint_states_topic,
            self.on_joint_states,
            10,
        )

        self.tf_buffer = Buffer()
        self.tf_listener = TransformListener(self.tf_buffer, self)

        self.ik_client = self.create_client(GetPositionIK, "/compute_ik")
        self.move_group_client = ActionClient(self, MoveGroup, "move_action")
        self.display_pub = self.create_publisher(
            DisplayTrajectory,
            "/display_planned_path",
            10,
        )

        self.get_logger().info(
            "visual_pregrasp_palm_ik_once listo | "
            f"detections={self.detections_topic} | group={self.planning_group} | "
            f"ik_link={self.ik_link} | palm_link={self.palm_link} | "
            f"target_class='{self.target_class or 'highest_confidence'}' | "
            f"ik_only={self.ik_only} | plan_only={self.plan_only}"
        )

    def on_detections(self, msg):
        self.latest_detections = msg

    def on_joint_states(self, msg):
        self.latest_joint_state = msg

    @staticmethod
    def is_finite_position(p):
        return math.isfinite(p.x) and math.isfinite(p.y) and math.isfinite(p.z)

    @staticmethod
    def angular_delta(a, b):
        return math.atan2(math.sin(a - b), math.cos(a - b))

    @staticmethod
    def transform_to_matrix(tf_msg):
        t = tf_msg.transform.translation
        q = tf_msg.transform.rotation

        mat = quaternion_matrix([q.x, q.y, q.z, q.w])
        mat[0, 3] = t.x
        mat[1, 3] = t.y
        mat[2, 3] = t.z
        return mat

    @staticmethod
    def pose_matrix(position_xyz, quat_xyzw):
        mat = quaternion_matrix(quat_xyzw)
        mat[0, 3] = position_xyz[0]
        mat[1, 3] = position_xyz[1]
        mat[2, 3] = position_xyz[2]
        return mat

    @staticmethod
    def matrix_to_pose_stamped(mat, frame_id, stamp_msg):
        pose = PoseStamped()
        pose.header.frame_id = frame_id
        pose.header.stamp = stamp_msg

        pose.pose.position.x = float(mat[0, 3])
        pose.pose.position.y = float(mat[1, 3])
        pose.pose.position.z = float(mat[2, 3])

        q = quaternion_from_matrix(mat)
        pose.pose.orientation.x = float(q[0])
        pose.pose.orientation.y = float(q[1])
        pose.pose.orientation.z = float(q[2])
        pose.pose.orientation.w = float(q[3])
        return pose

    def lookup_tf_matrix(self, target_frame, source_frame, timeout_s=3.0):
        deadline = self.get_clock().now() + Duration(seconds=timeout_s)
        last_error = None

        while rclpy.ok() and self.get_clock().now() < deadline:
            try:
                tf = self.tf_buffer.lookup_transform(
                    target_frame,
                    source_frame,
                    Time(),
                    timeout=Duration(seconds=0.2),
                )
                return self.transform_to_matrix(tf)
            except TransformException as e:
                last_error = e
                rclpy.spin_once(self, timeout_sec=0.05)

        self.get_logger().error(
            f"No pude leer TF {target_frame} <- {source_frame}. "
            f"Último error: {last_error}"
        )
        return None

    def wait_for_joint_state(self):
        self.get_logger().info("Esperando /joint_states...")
        start = self.get_clock().now()

        while rclpy.ok():
            rclpy.spin_once(self, timeout_sec=0.1)

            if self.latest_joint_state is not None:
                names = list(self.latest_joint_state.name)
                if all(j in names for j in RIGHT_ARM_JOINTS):
                    return self.latest_joint_state

            elapsed = (self.get_clock().now() - start).nanoseconds / 1e9
            if elapsed > self.wait_joint_state_timeout_s:
                self.get_logger().error(
                    "Timeout esperando /joint_states con joints del Right_arm."
                )
                return None

    def wait_for_detection(self):
        self.get_logger().info(
            f"Esperando detecciones en {self.detections_topic} "
            f"por hasta {self.wait_detection_timeout_s:.1f} s..."
        )

        start = self.get_clock().now()

        while rclpy.ok():
            rclpy.spin_once(self, timeout_sec=0.1)

            if self.latest_detections is not None and self.latest_detections.objects:
                target = self.select_target(self.latest_detections)
                if target is not None:
                    return target

            elapsed = (self.get_clock().now() - start).nanoseconds / 1e9
            if elapsed > self.wait_detection_timeout_s:
                self.get_logger().error("Timeout esperando detección válida.")
                return None

    def select_target(self, msg):
        candidates = []

        for det in msg.objects:
            if det.confidence < self.min_confidence:
                continue

            if self.target_class and det.class_name != self.target_class:
                continue

            if not self.is_finite_position(det.position):
                continue

            candidates.append(det)

        if not candidates:
            return None

        selected = max(candidates, key=lambda d: d.confidence)

        self.get_logger().info(
            f"Objetivo seleccionado: {selected.class_name} | "
            f"conf={selected.confidence:.3f} | "
            f"pos=({selected.position.x:.3f}, "
            f"{selected.position.y:.3f}, "
            f"{selected.position.z:.3f})"
        )

        return selected

    def extract_joint_map(self, joint_state_msg, wanted_joints):
        joint_map = {}

        for name, pos in zip(joint_state_msg.name, joint_state_msg.position):
            if name in wanted_joints and name not in joint_map:
                joint_map[name] = float(pos)

        missing = [j for j in wanted_joints if j not in joint_map]
        if missing:
            self.get_logger().error(f"Faltan joints en JointState: {missing}")
            return None

        return joint_map

    def build_seed_robot_state(self, joint_state_msg):
        robot_state = RobotState()
        robot_state.joint_state = deepcopy(joint_state_msg)
        robot_state.is_diff = False
        return robot_state

    def build_tool_target_from_palm_target(self, target_det):
        """
        Queremos que palm_link quede sobre el objeto.
        MoveIt controla ik_link=ur_dual_I_tool0.
        Por tanto:
            T_base_tool_target = T_base_palm_target * inv(T_tool_palm)
        """

        # TF actual de base -> palm. Usamos su orientación actual como orientación
        # deseada para la palma durante el pre-grasp.
        T_base_palm_current = self.lookup_tf_matrix(self.target_frame, self.palm_link)
        if T_base_palm_current is None:
            return None

        # TF fijo/actual de tool0 -> palm.
        T_tool_palm = self.lookup_tf_matrix(self.ik_link, self.palm_link)
        if T_tool_palm is None:
            return None

        # Orientación actual de la palma.
        q_base_palm_current = quaternion_from_matrix(T_base_palm_current)

        palm_target_xyz = np.array([
            float(target_det.position.x),
            float(target_det.position.y),
            float(target_det.position.z + self.pregrasp_offset_z),
        ])

        T_base_palm_target = self.pose_matrix(
            palm_target_xyz,
            q_base_palm_current,
        )

        T_base_tool_target = T_base_palm_target @ inverse_matrix(T_tool_palm)

        tool_pose = self.matrix_to_pose_stamped(
            T_base_tool_target,
            self.target_frame,
            self.get_clock().now().to_msg(),
        )

        self.get_logger().info(
            "Palm target deseado: "
            f"x={palm_target_xyz[0]:.3f}, "
            f"y={palm_target_xyz[1]:.3f}, "
            f"z={palm_target_xyz[2]:.3f}"
        )

        self.get_logger().info(
            "Tool target compensado para IK: "
            f"x={tool_pose.pose.position.x:.3f}, "
            f"y={tool_pose.pose.position.y:.3f}, "
            f"z={tool_pose.pose.position.z:.3f}"
        )

        return tool_pose

    def call_compute_ik(self, pose_stamped, seed_state):
        self.get_logger().info("Esperando servicio /compute_ik...")
        if not self.ik_client.wait_for_service(timeout_sec=3.0):
            self.get_logger().error("/compute_ik no está disponible.")
            return None

        req = GetPositionIK.Request()
        req.ik_request.group_name = self.planning_group
        req.ik_request.ik_link_name = self.ik_link
        req.ik_request.pose_stamped = pose_stamped
        req.ik_request.robot_state = seed_state
        req.ik_request.avoid_collisions = True
        req.ik_request.timeout.sec = int(self.ik_timeout_s)
        req.ik_request.timeout.nanosec = int((self.ik_timeout_s % 1.0) * 1e9)

        self.get_logger().info("Llamando /compute_ik...")
        future = self.ik_client.call_async(req)
        rclpy.spin_until_future_complete(self, future)

        if future.result() is None:
            self.get_logger().error("No hubo respuesta de /compute_ik.")
            return None

        res = future.result()
        error_code = res.error_code.val

        if error_code != 1:
            self.get_logger().error(f"/compute_ik falló. error_code={error_code}")
            return None

        self.get_logger().info("✓ /compute_ik encontró solución.")
        return res.solution.joint_state

    def validate_joint_solution(self, current_map, ik_map):
        self.get_logger().info("Comparando joints actuales vs IK:")

        ok = True

        for joint in RIGHT_ARM_JOINTS:
            current = current_map[joint]
            target = ik_map[joint]
            delta = self.angular_delta(target, current)
            delta_deg = math.degrees(delta)

            self.get_logger().info(
                f"  {joint}: actual={current:+.3f} rad | "
                f"ik={target:+.3f} rad | "
                f"delta={delta:+.3f} rad ({delta_deg:+.1f} deg)"
            )

            if abs(delta) > self.max_joint_delta_rad:
                ok = False
                self.get_logger().error(
                    f"  Cambio excesivo en {joint}: "
                    f"{abs(delta):.3f} rad > {self.max_joint_delta_rad:.3f} rad"
                )

        if ok:
            self.get_logger().info("✓ Solución IK pasa filtro de deltas articulares.")
        else:
            self.get_logger().error("✗ Solución IK rechazada por deltas articulares.")

        return ok

    def create_joint_goal_request(self, ik_joint_map):
        request = MotionPlanRequest()
        request.group_name = self.planning_group
        request.allowed_planning_time = 10.0
        request.num_planning_attempts = 5
        request.max_velocity_scaling_factor = self.velocity_scaling
        request.max_acceleration_scaling_factor = self.acceleration_scaling

        constraints = Constraints()

        for joint_name in RIGHT_ARM_JOINTS:
            jc = JointConstraint()
            jc.joint_name = joint_name
            jc.position = float(ik_joint_map[joint_name])
            jc.tolerance_above = 0.01
            jc.tolerance_below = 0.01
            jc.weight = 1.0
            constraints.joint_constraints.append(jc)

        request.goal_constraints.append(constraints)
        return request

    def execute_move_group_request(self, request):
        self.get_logger().info("Esperando /move_action...")
        while not self.move_group_client.wait_for_server(timeout_sec=1.0):
            self.get_logger().info("Todavía esperando /move_action...")

        goal_msg = MoveGroup.Goal()
        goal_msg.request = request
        goal_msg.planning_options.plan_only = self.plan_only
        goal_msg.planning_options.planning_scene_diff.is_diff = True
        goal_msg.planning_options.planning_scene_diff.robot_state.is_diff = True

        self.get_logger().info(
            "Enviando goal a MoveIt "
            f"({'SOLO PLAN' if self.plan_only else 'PLAN + EJECUCIÓN'})..."
        )

        send_future = self.move_group_client.send_goal_async(goal_msg)
        rclpy.spin_until_future_complete(self, send_future)

        goal_handle = send_future.result()
        if goal_handle is None:
            self.get_logger().error("No se recibió goal_handle.")
            return False

        if not goal_handle.accepted:
            self.get_logger().error("Goal rechazado por MoveIt.")
            return False

        self.get_logger().info("Goal aceptado. Esperando resultado...")

        result_future = goal_handle.get_result_async()
        rclpy.spin_until_future_complete(self, result_future)

        result = result_future.result()
        if result is None:
            self.get_logger().error("No se recibió resultado.")
            return False

        error_code = result.result.error_code.val

        try:
            display_msg = DisplayTrajectory()
            display_msg.trajectory_start = result.result.trajectory_start
            display_msg.trajectory.append(result.result.planned_trajectory)
            self.display_pub.publish(display_msg)
            self.get_logger().info("Plan publicado en /display_planned_path para RViz.")
        except Exception as e:
            self.get_logger().warn(f"No pude publicar DisplayTrajectory: {e}")

        if error_code == 1:
            self.get_logger().info("✓ MoveIt completó correctamente.")
            return True

        self.get_logger().error(f"✗ MoveIt falló. error_code={error_code}")
        return False

    def run_once(self):
        current_joint_state = self.wait_for_joint_state()
        if current_joint_state is None:
            return False

        current_map = self.extract_joint_map(current_joint_state, RIGHT_ARM_JOINTS)
        if current_map is None:
            return False

        target = self.wait_for_detection()
        if target is None:
            return False

        tool_target_pose = self.build_tool_target_from_palm_target(target)
        if tool_target_pose is None:
            return False

        seed_state = self.build_seed_robot_state(current_joint_state)

        ik_joint_state = self.call_compute_ik(tool_target_pose, seed_state)
        if ik_joint_state is None:
            return False

        ik_map = self.extract_joint_map(ik_joint_state, RIGHT_ARM_JOINTS)
        if ik_map is None:
            return False

        if not self.validate_joint_solution(current_map, ik_map):
            return False

        if self.ik_only:
            self.get_logger().info("ik_only=True: no se planifica ni se ejecuta. Fin seguro.")
            return True

        request = self.create_joint_goal_request(ik_map)
        return self.execute_move_group_request(request)


def main(args=None):
    rclpy.init(args=args)
    node = VisualPregraspPalmIKOnce()

    try:
        node.run_once()
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
