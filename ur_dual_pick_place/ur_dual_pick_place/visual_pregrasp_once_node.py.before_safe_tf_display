#!/usr/bin/env python3
# -----------------------------------------------------------------------------
# TFG Daniel Rodríguez Rivas
# Hito: visual pre-grasp dinámico.
#
# Lee /object_tracker/detections_base, selecciona un objeto válido y mueve
# Right_arm para colocar ur_dual_I_tool0 encima del objeto detectado.
# -----------------------------------------------------------------------------

import math

import rclpy
from rclpy.node import Node
from rclpy.action import ActionClient
from rclpy.duration import Duration
from rclpy.time import Time

from tf2_ros import Buffer, TransformListener, TransformException

from moveit_msgs.action import MoveGroup
from moveit_msgs.msg import (
    MotionPlanRequest,
    Constraints,
    PositionConstraint,
    OrientationConstraint,
)
from shape_msgs.msg import SolidPrimitive
from geometry_msgs.msg import Pose

from stereo_location_interfaces.msg import ObjDetArray


class VisualPregraspOnce(Node):
    def __init__(self):
        super().__init__("visual_pregrasp_once")

        self.declare_parameter("detections_topic", "/object_tracker/detections_base")
        self.declare_parameter("target_frame", "ur_dual_I_base_link")
        self.declare_parameter("planning_group", "Right_arm")
        self.declare_parameter("ee_link", "ur_dual_I_tool0")

        # Si target_class queda vacío, se elige el objeto con mayor confianza.
        self.declare_parameter("target_class", "")
        self.declare_parameter("min_confidence", 0.55)

        # Offset seguro inicial. Si queda muy alto, luego bajamos.
        self.declare_parameter("pregrasp_offset_z", 0.25)

        # Radio de tolerancia del objetivo cartesiano.
        self.declare_parameter("position_tolerance_m", 0.04)

        # Velocidades bajas para prueba física segura.
        self.declare_parameter("velocity_scaling", 0.05)
        self.declare_parameter("acceleration_scaling", 0.05)

        self.declare_parameter("wait_detection_timeout_s", 5.0)

        # Primero puedes probar con plan_only:=true.
        self.declare_parameter("plan_only", False)

        self.detections_topic = self.get_parameter("detections_topic").value
        self.target_frame = self.get_parameter("target_frame").value
        self.planning_group = self.get_parameter("planning_group").value
        self.ee_link = self.get_parameter("ee_link").value
        self.target_class = self.get_parameter("target_class").value.strip()
        self.min_confidence = float(self.get_parameter("min_confidence").value)
        self.pregrasp_offset_z = float(self.get_parameter("pregrasp_offset_z").value)
        self.position_tolerance_m = float(self.get_parameter("position_tolerance_m").value)
        self.velocity_scaling = float(self.get_parameter("velocity_scaling").value)
        self.acceleration_scaling = float(self.get_parameter("acceleration_scaling").value)
        self.wait_detection_timeout_s = float(self.get_parameter("wait_detection_timeout_s").value)
        self.plan_only = bool(self.get_parameter("plan_only").value)

        self.latest_msg = None

        self.sub = self.create_subscription(
            ObjDetArray,
            self.detections_topic,
            self.on_detections,
            10,
        )

        self.tf_buffer = Buffer()
        self.tf_listener = TransformListener(self.tf_buffer, self)

        self.move_group_client = ActionClient(self, MoveGroup, "move_action")

        self.get_logger().info(
            f"visual_pregrasp_once listo | topic={self.detections_topic} | "
            f"group={self.planning_group} | ee_link={self.ee_link} | "
            f"target_class='{self.target_class or 'highest_confidence'}' | "
            f"plan_only={self.plan_only}"
        )

    @staticmethod
    def is_finite_position(p):
        return math.isfinite(p.x) and math.isfinite(p.y) and math.isfinite(p.z)

    def on_detections(self, msg):
        self.latest_msg = msg

    def wait_for_detection(self):
        self.get_logger().info(
            f"Esperando detecciones en {self.detections_topic} "
            f"por hasta {self.wait_detection_timeout_s:.1f} s..."
        )

        start = self.get_clock().now()

        while rclpy.ok():
            rclpy.spin_once(self, timeout_sec=0.1)

            if self.latest_msg is not None and self.latest_msg.objects:
                target = self.select_target(self.latest_msg)
                if target is not None:
                    return target

            elapsed = (self.get_clock().now() - start).nanoseconds / 1e9
            if elapsed > self.wait_detection_timeout_s:
                self.get_logger().error("Timeout esperando una detección válida.")
                return None

    def select_target(self, msg):
        candidates = []

        for det in msg.objects:
            if det.confidence < self.min_confidence:
                continue

            if self.target_class and det.class_name != self.target_class:
                continue

            if not self.is_finite_position(det.position):
                continue

            candidates.append(det)

        if not candidates:
            return None

        # Para el primer prototipo: mayor confianza.
        selected = max(candidates, key=lambda d: d.confidence)

        self.get_logger().info(
            f"Objetivo seleccionado: {selected.class_name} | "
            f"conf={selected.confidence:.3f} | "
            f"pos=({selected.position.x:.3f}, "
            f"{selected.position.y:.3f}, "
            f"{selected.position.z:.3f})"
        )

        return selected

    def get_current_tool_orientation(self):
        """
        Obtiene la orientación actual de ur_dual_I_tool0 respecto a ur_dual_I_base_link.
        Esto permite mover a una nueva posición manteniendo una orientación ya válida.
        """
        try:
            tf = self.tf_buffer.lookup_transform(
                self.target_frame,
                self.ee_link,
                Time(),
                timeout=Duration(seconds=1.0),
            )
            return tf.transform.rotation
        except TransformException as e:
            self.get_logger().warn(
                f"No pude leer orientación actual de {self.ee_link}. "
                f"Usaré orientación identidad. Detalle: {e}"
            )
            # Fallback conservador.
            from geometry_msgs.msg import Quaternion
            q = Quaternion()
            q.w = 1.0
            return q

    def create_pose_goal_request(self, target_det):
        target_x = float(target_det.position.x)
        target_y = float(target_det.position.y)
        target_z = float(target_det.position.z + self.pregrasp_offset_z)

        self.get_logger().info(
            f"Pre-grasp target para {self.ee_link}: "
            f"x={target_x:.3f}, y={target_y:.3f}, z={target_z:.3f} "
            f"(offset_z={self.pregrasp_offset_z:.3f})"
        )

        request = MotionPlanRequest()
        request.group_name = self.planning_group
        request.allowed_planning_time = 10.0
        request.num_planning_attempts = 5
        request.max_velocity_scaling_factor = self.velocity_scaling
        request.max_acceleration_scaling_factor = self.acceleration_scaling

        constraints = Constraints()

        # Position constraint: una esfera pequeña centrada en el pre-grasp.
        position_constraint = PositionConstraint()
        position_constraint.header.frame_id = self.target_frame
        position_constraint.link_name = self.ee_link
        position_constraint.weight = 1.0

        sphere = SolidPrimitive()
        sphere.type = SolidPrimitive.SPHERE
        sphere.dimensions = [self.position_tolerance_m]

        sphere_pose = Pose()
        sphere_pose.position.x = target_x
        sphere_pose.position.y = target_y
        sphere_pose.position.z = target_z
        sphere_pose.orientation.w = 1.0

        position_constraint.constraint_region.primitives.append(sphere)
        position_constraint.constraint_region.primitive_poses.append(sphere_pose)

        constraints.position_constraints.append(position_constraint)

        # Orientation constraint: mantener aproximadamente la orientación actual.
        # Tolerancias amplias para no bloquear el plan.
        current_orientation = self.get_current_tool_orientation()

        orientation_constraint = OrientationConstraint()
        orientation_constraint.header.frame_id = self.target_frame
        orientation_constraint.link_name = self.ee_link
        orientation_constraint.orientation = current_orientation
        orientation_constraint.absolute_x_axis_tolerance = 0.8
        orientation_constraint.absolute_y_axis_tolerance = 0.8
        orientation_constraint.absolute_z_axis_tolerance = 3.14
        orientation_constraint.weight = 0.3

        constraints.orientation_constraints.append(orientation_constraint)

        request.goal_constraints.append(constraints)
        return request

    def execute_move_group_request(self, request):
        self.get_logger().info("Esperando /move_action...")
        while not self.move_group_client.wait_for_server(timeout_sec=1.0):
            self.get_logger().info("Todavía esperando /move_action...")

        goal_msg = MoveGroup.Goal()
        goal_msg.request = request
        goal_msg.planning_options.plan_only = self.plan_only
        goal_msg.planning_options.planning_scene_diff.is_diff = True
        goal_msg.planning_options.planning_scene_diff.robot_state.is_diff = True

        self.get_logger().info(
            "Enviando goal a MoveIt "
            f"({'SOLO PLAN' if self.plan_only else 'PLAN + EJECUCIÓN'})..."
        )

        send_future = self.move_group_client.send_goal_async(goal_msg)
        rclpy.spin_until_future_complete(self, send_future)

        goal_handle = send_future.result()
        if goal_handle is None:
            self.get_logger().error("No se recibió goal_handle.")
            return False

        if not goal_handle.accepted:
            self.get_logger().error("Goal rechazado por MoveIt.")
            return False

        self.get_logger().info("Goal aceptado. Esperando resultado...")

        result_future = goal_handle.get_result_async()
        rclpy.spin_until_future_complete(self, result_future)

        result = result_future.result()
        if result is None:
            self.get_logger().error("No se recibió resultado.")
            return False

        error_code = result.result.error_code.val

        if error_code == 1:
            self.get_logger().info("✓ MoveIt completó correctamente.")
            return True

        self.get_logger().error(f"✗ MoveIt falló. error_code={error_code}")
        return False

    def run_once(self):
        target = self.wait_for_detection()
        if target is None:
            return False

        request = self.create_pose_goal_request(target)
        return self.execute_move_group_request(request)


def main(args=None):
    rclpy.init(args=args)
    node = VisualPregraspOnce()

    try:
        node.run_once()
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
